# ---- Privy (client-side, safe to expose) ----
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ---- Privy (server-side ONLY — never expose to the client) ----
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ---- Database (Neon Postgres) ----
# Injected automatically by the Vercel Neon integration in production.
DATABASE_URL=

# ---- Solana escrow (bounty deposits & payouts) ----
# Public address users send deposits to (defaults to keypair pubkey if secret set).
ESCROW_WALLET_ADDRESS=
# Base58 secret key OR JSON byte array — server-only, never expose.
# Required for payouts and refunds (server signs releases from escrow).
ESCROW_WALLET_SECRET_KEY=
# Rate limiting for financial APIs uses Postgres table api_rate_limits (migration 018).
# Use devnet for testing: https://api.devnet.solana.com + SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta

# ---- Landing / token (optional) ----
NEXT_PUBLIC_SITE_URL=https://gloria.finance
# Set these after the official GLORIA social profile is confirmed.
NEXT_PUBLIC_TWITTER_HANDLE=
NEXT_PUBLIC_TWITTER_URL=
# Official $GLORIA contract address.
NEXT_PUBLIC_TOKEN_CA=DxbU8EpEjHm1AWyzPtAXw3FGoGGo4PbNeJcmtaFQpump
NEXT_PUBLIC_DEXSCREENER_URL=
